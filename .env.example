# FocusBoard Docker configuration
# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.

# Required: encryption key for your stored credentials.
# Generate a random key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Keep this safe and stable — if you change it you will need to re-enter all your API tokens.
FOCUSBOARD_KEY=replace-this-with-a-random-secret
